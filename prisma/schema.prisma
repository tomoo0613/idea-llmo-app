generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppSettings {
  id           String   @id @default("singleton")
  openaiApiKey String?
  geminiApiKey String?
  claudeApiKey String?
  updatedAt    DateTime @updatedAt
}

model Project {
  id              String           @id @default(cuid())
  name            String
  description     String?
  prompt          String           @default("")
  targetDomain    String           @default("")
  targetServices  String           @default("[]")
  targetCustomer  String           @default("")
  ruleMaking      String           @default("")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  analyses        Analysis[]
  recommendations Recommendation[]
  surveys         Survey[]
}

model Survey {
  id          String         @id @default(cuid())
  projectId   String
  status      String         @default("pending")
  totalSteps  Int            @default(0)
  doneSteps   Int            @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results     SurveyResult[]

  @@index([projectId])
}

model SurveyResult {
  id                String   @id @default(cuid())
  surveyId          String
  promptIndex       Int      @default(0)
  promptText        String   @default("")
  modelVariant      String
  provider          String
  modelId           String
  searchEnabled     Boolean  @default(false)
  responseText      String   @default("")
  responseTimeMs    Int?
  serviceMentions   String   @default("{}")
  targetDomainCited Boolean  @default(false)
  citedUrls         String   @default("[]")
  error             String?
  createdAt         DateTime @default(now())
  survey            Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, promptIndex, modelVariant])
  @@index([surveyId])
}

model Analysis {
  id               String   @id @default(cuid())
  projectId        String
  surveyId         String?
  overallScore     Float
  openaiScore      Float
  geminiScore      Float
  claudeScore      Float
  keywordCoverage  Float
  citationRate     Float
  avgPosition      Float?
  mentionBreakdown String
  promptScores     String
  strengths        String
  weaknesses       String
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Recommendation {
  id               String   @id @default(cuid())
  projectId        String
  analysisId       String?
  priority         Int      @default(0)
  category         String
  title            String
  description      String
  rationale        String
  suggestedContent String?
  targetPrompts    String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([priority])
}
