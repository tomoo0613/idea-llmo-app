generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppSettings {
  id           String   @id @default("singleton")
  openaiApiKey String?
  geminiApiKey String?
  claudeApiKey String?
  updatedAt    DateTime @updatedAt
}

model Project {
  id              String           @id @default(cuid())
  name            String
  description     String?
  prompt          String           @default("")
  targetDomain    String           @default("")
  targetServices  String           @default("[]")
  targetCustomer  String           @default("")
  ruleMaking      String           @default("")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  analyses        Analysis[]
  recommendations Recommendation[]
  surveys         Survey[]
  diagnoses       Diagnosis[]
}

model Survey {
  id          String         @id @default(cuid())
  projectId   String
  status      String         @default("pending")
  totalSteps  Int            @default(0)
  doneSteps   Int            @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results     SurveyResult[]

  @@index([projectId])
}

model SurveyResult {
  id                String   @id @default(cuid())
  surveyId          String
  promptIndex       Int      @default(0)
  promptText        String   @default("")
  modelVariant      String
  provider          String
  modelId           String
  searchEnabled     Boolean  @default(false)
  responseText      String   @default("")
  responseTimeMs    Int?
  serviceMentions   String   @default("{}")
  targetDomainCited Boolean  @default(false)
  citedUrls         String   @default("[]")
  error             String?
  createdAt         DateTime @default(now())
  survey            Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, promptIndex, modelVariant])
  @@index([surveyId])
}

model Analysis {
  id               String   @id @default(cuid())
  projectId        String
  surveyId         String?
  overallScore     Float
  openaiScore      Float
  geminiScore      Float
  claudeScore      Float
  keywordCoverage  Float
  citationRate     Float
  avgPosition      Float?
  mentionBreakdown String
  promptScores     String
  strengths        String
  weaknesses       String
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Diagnosis {
  id          String   @id @default(cuid())
  projectId   String
  scores      String   @default("{}") // JSON: { "1": 5, "2": 3, ... }
  notes       String   @default("{}") // JSON: { "1": "メモ", ... }
  totalScore  Float    @default(0)
  maxScore    Float    @default(100)
  categoryA   Float    @default(0) // 技術的要素・アクセシビリティ
  categoryB   Float    @default(0) // 権威性・信頼性（E-E-A-T）
  categoryC   Float    @default(0) // コンテンツ適合性
  categoryD   Float    @default(0) // 外部評価・サイテーション
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Recommendation {
  id               String   @id @default(cuid())
  projectId        String
  analysisId       String?
  priority         Int      @default(0)
  category         String
  title            String
  description      String
  rationale        String
  suggestedContent String?
  targetPrompts    String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([priority])
}
